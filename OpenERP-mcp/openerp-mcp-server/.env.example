# --- OpenERP MCP server configuration -------------------------------------
# Copy to ".env" and fill in. The server connects over HTTPS only (Traefik proxy).

# Required ------------------------------------------------------------------
OPENERP_HOST=erp.example.com
OPENERP_DB=mycompany
OPENERP_LOGIN=admin
OPENERP_PASSWORD=change-me

# Optional ------------------------------------------------------------------
# TLS port exposed by Traefik (443 is standard).
OPENERP_PORT=443
# xmlrpcs (default, recommended for OpenERP 7) or jsonrpcs. Both HTTPS-only.
OPENERP_PROTOCOL=xmlrpcs
# URL path prefix if Traefik routes OpenERP under a sub-path (e.g. "erp"). Empty = none.
OPENERP_BASE_PATH=
# Request timeout, seconds.
OPENERP_TIMEOUT=30
# Verify the proxy TLS certificate. Keep "true" in production.
OPENERP_VERIFY_TLS=true
# Emergency override to allow plain HTTP. Leave unset / false.
OPENERP_ALLOW_INSECURE=false

# Business layer locking (neutral when empty) -------------------------------
# Comma-separated account.account codes that become read-only.
OPENERP_LOCKED_ACCOUNTS=
# Comma-separated account.journal codes that become read-only.
OPENERP_LOCKED_JOURNALS=
